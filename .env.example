# OpenAI API Key (或兼容的 LLM 服务)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4

# MySQL 主数据源 (模拟主业务库)
MYSQL_PRIMARY_URL=jdbc:mysql://localhost:3306/business_db?useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_PRIMARY_USERNAME=root
MYSQL_PRIMARY_PASSWORD=your_password_here

# MySQL 只读数据源 (AI 沙箱账号)
MYSQL_READONLY_URL=jdbc:mysql://localhost:3306/business_db?useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_READONLY_USERNAME=readonly_user
MYSQL_READONLY_PASSWORD=readonly_password_here

# Java 服务地址 (Python 调用)
JAVA_SERVICE_URL=http://localhost:8080
